# ============================================================
# API KEYS (required)
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs Text-to-Speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ============================================================
# MODEL SELECTION
# Update these when new models release — no code changes needed.
# ============================================================

# Claude (Primary)
# CLAUDE_ANALYSIS_MODEL=claude-opus-4-5
# CLAUDE_CODE_MODEL=claude-sonnet-4-5
# CLAUDE_LIGHT_MODEL=claude-sonnet-4-5
# CLAUDE_HEARTBEAT_MODEL=claude-haiku-4-5

# OpenAI (Fallback 1)
# OPENAI_ANALYSIS_MODEL=gpt-4o
# OPENAI_CODE_MODEL=o4-mini
# OPENAI_LIGHT_MODEL=gpt-4o-mini
# OPENAI_HEARTBEAT_MODEL=gpt-4o-mini

# Gemini (Fallback 2)
# GEMINI_ANALYSIS_MODEL=gemini-2.5-pro-preview-03-25
# GEMINI_LIGHT_MODEL=gemini-2.5-flash
# GEMINI_HEARTBEAT_MODEL=gemini-2.5-flash

# ============================================================
# INTEGRATIONS
# ============================================================

# Gmail
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Twitter API
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# GitHub
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username

# Cricket Data API (https://cricketdata.org)
CRICKET_API_KEY=your_cricket_api_key_here

# Paths (absolute paths)
SANDBOX_PATH=/path/to/your/sandbox
OBSIDIAN_PATH=/path/to/your/obsidian/vault
DATA_PATH=/path/to/your/data
